using MatchResultBackend.Models;
using Microsoft.AspNetCore.Mvc;

namespace MatchResultBackend.Controllers
{
    [ApiController]
    [Route("[controller]")]
    public class MatchController : Controller
    {
        private List<MatchModel> matches = new List<MatchModel>();

        [HttpGet]
        public IActionResult GetAll()
        {
            matches.Add(new MatchModel { Team1 = "ETO", Team2 = "Fradi", Score1 = 3, Score2 = 1 });
            matches.Add(new MatchModel { Team1 = "ETO", Team2 = "Debrecen", Score1 = 2, Score2 = 2 });
            matches.Add(new MatchModel { Team1 = "Fehérvár", Team2 = "Fradi", Score1 = 3, Score2 = 4 });
            matches.Add(new MatchModel { Team1 = "Nagykanizsa", Team2 = "Kisvárda", Score1 = 3, Score2 = 6 });
            matches.Add(new MatchModel { Team1 = "Kispest", Team2 = "Győrszentiván", Score1 = 7, Score2 = 3 });
            return Ok(matches);
        }

        [HttpPost]
        public IActionResult AddMatch(MatchModel match)
        {
            matches.Add(match);
            return Ok(match);
        }
    }
}
